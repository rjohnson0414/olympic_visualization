  .og-sportbar-count { font-family: 'IBM Plex Mono', monospace; font-size: 11.5px; color: var(--slate); text-align: right; }

  .og-empty { color: var(--slate); font-size: 13px; }

  .og-table::-webkit-scrollbar { width: 6px; }
  .og-table::-webkit-scrollbar-thumb { background: var(--ink-3); border-radius: 3px; }
`;

export default function OlympicMedalDashboard() {
  const [status, setStatus] = useState("loading"); // loading | error | ready
  const [errorMsg, setErrorMsg] = useState("");
  const [data, setData] = useState(null);

  useEffect(() => {
    let cancelled = false;
    fetch(CSV_URL)
      .then((res) => {
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        return res.text();
      })
      .then((text) => {
        const parsed = Papa.parse(text, { header: true, skipEmptyLines: true });
        if (cancelled) return;
        const agg = buildAggregates(parsed.data);
        setData(agg);
        setStatus("ready");
      })
      .catch((err) => {
        if (cancelled) return;
        setErrorMsg(err.message || String(err));
        setStatus("error");
      });
    return () => {
      cancelled = true;
    };
  }, []);

  const [range, setMin, setMax, setRange] = useDualRange(data ? data.years.length : 1);
  const [selectedCountry, setSelectedCountry] = useState("USA");
  const [search, setSearch] = useState("");
  const [metric, setMetric] = useState("total");

  const years = data ? data.years : [];
  const minYear = years.length ? years[Math.min(range[0], years.length - 1)] : null;
  const maxYear = years.length ? years[Math.min(range[1], years.length - 1)] : null;

  const countryTotalsInRange = useMemo(() => {
    if (!data) return [];
    const map = new Map();
    for (const row of data.countryYear) {
      if (row.y < minYear || row.y > maxYear) continue;
      if (!map.has(row.c)) map.set(row.c, { c: row.c, g: 0, s: 0, b: 0, t: 0 });
      const e = map.get(row.c);
      e.g += row.g;
      e.s += row.s;
      e.b += row.b;
      e.t += row.t;
    }
    let arr = Array.from(map.values());
    if (search.trim()) {
      const q = search.trim().toLowerCase();
      arr = arr.filter(
        (e) =>
          (data.countries[e.c] || e.c).toLowerCase().includes(q) ||
          e.c.toLowerCase().includes(q)
      );
    }
    arr.sort((a, b) =>
      metric === "gold" ? b.g - a.g || b.t - a.t : b.t - a.t || b.g - a.g
    );
    return arr;
  }, [data, minYear, maxYear, search, metric]);

  const topList = countryTotalsInRange.slice(0, 15);

  const countryTrend = useMemo(() => {
    if (!data) return [];
    const rows = data.countryYear.filter((r) => r.c === selectedCountry);
    const byYear = new Map(rows.map((r) => [r.y, r]));
    return years.map(
      (y) => byYear.get(y) || { c: selectedCountry, y, g: 0, s: 0, b: 0, t: 0 }
    );
  }, [data, selectedCountry, years]);

  const countrySportTop = useMemo(() => {
    if (!data) return [];
    const rows = data.countrySport.filter((r) => r.c === selectedCountry);
    return [...rows].sort((a, b) => b.t - a.t).slice(0, 8);
  }, [data, selectedCountry]);

  const selectedTotals = useMemo(() => {
    let g = 0,
      s = 0,
      b = 0;
    for (const r of countryTrend) {
      if (r.y >= minYear && r.y <= maxYear) {
        g += r.g;
        s += r.s;
        b += r.b;
      }
    }
    return { g, s, b, t: g + s + b };
  }, [countryTrend, minYear, maxYear]);

  const heroStats = useMemo(() => {
    if (!data) return { totalMedals: 0, nations: 0, games: 0 };
    const totalMedals = data.yearData.reduce((a, y) => a + y.t, 0);
    const nations = Object.keys(data.countries).length;
    return { totalMedals, nations, games: years.length };
  }, [data, years]);

  if (status === "loading") {
    return (
      <div className="og-root">
        <style>{DASHBOARD_STYLES}</style>
        <div className="og-status">
          <div className="og-spinner" />
          <p className="og-status-title">Loading medal data…</p>
          <p className="og-status-body">Fetching and parsing the CSV from the configured source.</p>
        </div>
      </div>
    );
  }

  if (status === "error") {
    return (
      <div className="og-root">
        <style>{DASHBOARD_STYLES}</style>
        <div className="og-status">
          <p className="og-status-title">Couldn't load the medal data</p>
          <p className="og-status-body">
            The fetch to the CSV source failed ({errorMsg}). Make sure{" "}
            <code>CSV_URL</code> at the top of this file points to a
            reachable, CORS-enabled URL — a raw GitHub URL works well:
          </p>
          <p className="og-status-code">{CSV_URL}</p>
          <p className="og-status-body">
            After pushing <code>olympic_medals_1896_2012.csv</code> to your
            repo, replace the placeholder with the "Raw" URL GitHub gives
            you for that file.
          </p>
        </div>
      </div>
    );
  }

  const selectedName = data.countries[selectedCountry] || selectedCountry;

  return (
    <div className="og-root">
      <style>{DASHBOARD_STYLES}</style>

      <p className="og-eyebrow">
        {years[0]} – {years[years.length - 1]} · {heroStats.games} Editions
      </p>
      <h1 className="og-h1">
        Summer Games <span>Medal Archive</span>
      </h1>
      <p className="og-sub">
        Every medal awarded across {heroStats.games} editions of the Summer
        Olympics, from Athens {years[0]} to London {years[years.length - 1]}.
        Drag the track below to set a time window, then pick a nation to see
        its trajectory.
      </p>

      <div className="og-stats">
        <div>
          <div className="og-stat-num">{fmt(heroStats.totalMedals)}</div>
          <div className="og-stat-label">Medals awarded</div>
        </div>
        <div>
          <div className="og-stat-num">{heroStats.nations}</div>
          <div className="og-stat-label">Nations &amp; teams</div>
        </div>
        <div>
          <div className="og-stat-num">{data.sports.length}</div>
          <div className="og-stat-label">Sports contested</div>
        </div>
        <div>
          <div className="og-stat-num">{heroStats.games}</div>
          <div className="og-stat-label">Games held</div>
        </div>
      </div>

      <div className="og-track-section">
        <p className="og-track-title">Time window</p>
        <TrackSlider
          years={years}
          yearData={data.yearData}
          range={range}
          setMin={setMin}
          setMax={setMax}
          setRange={setRange}
        />
        <p className="og-range-label">
          Showing <b>{minYear}</b> – <b>{maxYear}</b> · click a lap marker to
          jump to a single Games
        </p>
      </div>

      <div className="og-grid">
        <div className="og-panel">
          <p className="og-panel-title">Medal table</p>
          <p className="og-panel-sub">
            Ranked {minYear}–{maxYear}
          </p>

          <div className="og-controls-row">
            <input
              className="og-search"
              placeholder="Search nation…"
              value={search}
              onChange={(e) => setSearch(e.target.value)}
            />
            <div className="og-segmented">
              <button
                className={`og-seg-btn ${metric === "total" ? "on" : ""}`}
                onClick={() => setMetric("total")}
              >
                Total
              </button>
              <button
                className={`og-seg-btn ${metric === "gold" ? "on" : ""}`}
                onClick={() => setMetric("gold")}
              >
                Gold
              </button>
            </div>
          </div>

          <div className="og-table">
            {topList.map((e, i) => {
              const val = metric === "gold" ? e.g : e.t;
              const gW = e.t ? (e.g / e.t) * 100 : 0;
              const sW = e.t ? (e.s / e.t) * 100 : 0;
              const bW = e.t ? (e.b / e.t) * 100 : 0;
              return (
                <button
                  key={e.c}
                  className={`og-row ${e.c === selectedCountry ? "on" : ""}`}
                  onClick={() => setSelectedCountry(e.c)}
                >
                  <span className="og-rank">{i + 1}</span>
                  <span className="og-cname">{data.countries[e.c] || e.c}</span>
                  <span className="og-mini-bar">
                    <span className="og-mini-seg-g" style={{ width: `${gW}%` }} />
                    <span className="og-mini-seg-s" style={{ width: `${sW}%` }} />
                    <span className="og-mini-seg-b" style={{ width: `${bW}%` }} />
                  </span>
                  <span className="og-total">{fmt(val)}</span>
                </button>
              );
            })}
            {topList.length === 0 && (
              <p className="og-empty">No nations match "{search}" in this window.</p>
            )}
          </div>

          <div className="og-legend">
            <span className="og-legend-item">
              <span className="og-legend-dot" style={{ background: MEDAL_COLOR.g }} /> Gold
            </span>
            <span className="og-legend-item">
              <span className="og-legend-dot" style={{ background: MEDAL_COLOR.s }} /> Silver
            </span>
            <span className="og-legend-item">
              <span className="og-legend-dot" style={{ background: MEDAL_COLOR.b }} /> Bronze
            </span>
          </div>
        </div>

        <div className="og-panel">
          <p className="og-panel-title">Nation focus</p>
          <p className="og-panel-sub">{selectedName}</p>

          <div className="og-country-totals">
            <div>
              <div className="og-ct-num" style={{ color: MEDAL_COLOR.g }}>{selectedTotals.g}</div>
              <div className="og-ct-label">Gold</div>
            </div>
            <div>
              <div className="og-ct-num" style={{ color: MEDAL_COLOR.s }}>{selectedTotals.s}</div>
              <div className="og-ct-label">Silver</div>
            </div>
            <div>
              <div className="og-ct-num" style={{ color: MEDAL_COLOR.b }}>{selectedTotals.b}</div>
              <div className="og-ct-label">Bronze</div>
            </div>
            <div>
              <div className="og-ct-num">{selectedTotals.t}</div>
              <div className="og-ct-label">In window</div>
            </div>
          </div>

          <TrendChart trend={countryTrend} lo={range[0]} hi={range[1]} metric={metric} />

          <p className="og-panel-title" style={{ marginTop: 20 }}>
            Strongest sports · all-time
          </p>
          <SportBars rows={countrySportTop} />
        </div>
      </div>
    </div>
  );
}
