function fmt(n) {
  return n.toLocaleString("en-US");
}

function buildAggregates(rows) {
  const hostByYear = new Map();
  const cy = new Map(); // "code|year" -> {g,s,b}
  const cs = new Map(); // "code|sport" -> {g,s,b}
  const yearTotals = new Map(); // year -> {g,s,b}
  const sportsSet = new Set();
  const countryCodes = new Set();

  for (const row of rows) {
    const year = parseInt(row.Year, 10);
    if (!year) continue;
    const code = (row.Country || "").trim();
    const sport = (row.Sport || "").trim();
    const medal = (row.Medal || "").trim().toLowerCase();
    if (!hostByYear.has(year)) hostByYear.set(year, row.City);
    if (sport) sportsSet.add(sport);
    if (!code) continue;
    countryCodes.add(code);

    const cyKey = code + "|" + year;
    if (!cy.has(cyKey)) cy.set(cyKey, { g: 0, s: 0, b: 0 });
    const cyE = cy.get(cyKey);

    const csKey = code + "|" + sport;
    if (!cs.has(csKey)) cs.set(csKey, { g: 0, s: 0, b: 0 });
    const csE = cs.get(csKey);

    if (!yearTotals.has(year)) yearTotals.set(year, { g: 0, s: 0, b: 0 });
    const ytE = yearTotals.get(year);

    if (medal === "gold") {
      cyE.g++; csE.g++; ytE.g++;
    } else if (medal === "silver") {
      cyE.s++; csE.s++; ytE.s++;
    } else if (medal === "bronze") {
      cyE.b++; csE.b++; ytE.b++;
    }
  }

  const years = Array.from(hostByYear.keys()).sort((a, b) => a - b);

  const countries = {};
  for (const code of countryCodes) {
    countries[code] = CODE_NAMES[code] || code;
  }

  const countryYear = [];
  for (const [key, v] of cy.entries()) {
    const [c, yStr] = key.split("|");
    const t = v.g + v.s + v.b;
    if (t === 0) continue;
    countryYear.push({ c, y: parseInt(yStr, 10), g: v.g, s: v.s, b: v.b, t });
  }

  const countrySport = [];
  for (const [key, v] of cs.entries()) {
    const idx = key.indexOf("|");
    const c = key.slice(0, idx);
    const sp = key.slice(idx + 1);
    const t = v.g + v.s + v.b;
    if (t === 0 || !sp) continue;
    countrySport.push({ c, sp, g: v.g, s: v.s, b: v.b, t });
  }

  const yearData = years.map((y) => {
    const v = yearTotals.get(y) || { g: 0, s: 0, b: 0 };
    return {
      y,
      city: hostByYear.get(y),
      g: v.g,
      s: v.s,
      b: v.b,
      t: v.g + v.s + v.b,
    };
  });

  const sports = Array.from(sportsSet).sort();

  return { years, countries, countryYear, countrySport, yearData, sports };
}

function useDualRange(len) {
  const [range, setRange] = useState([0, Math.max(0, len - 1)]);
  const setMin = useCallback((v) => {
    setRange(([lo, hi]) => [Math.min(v, hi), hi]);
  }, []);
  const setMax = useCallback((v) => {
    setRange(([lo, hi]) => [lo, Math.max(v, lo)]);
  }, []);
  return [range, setMin, setMax, setRange];
}

function TrackSlider({ years, yearData, range, setMin, setMax, setRange }) {
  const n = years.length;
  const maxTotal = Math.max(1, ...yearData.map((d) => d.t));
  const [lo, hi] = range;

  return (
    <div className="og-track-wrap">
      <div className="og-track-lanes" aria-hidden="true">
        <div className="og-lane" />
        <div className="og-lane" />
        <div className="og-lane" />
        <div
          className="og-track-fill"
          style={{
            left: `${(lo / (n - 1)) * 100}%`,
            right: `${100 - (hi / (n - 1)) * 100}%`,
          }}
        />
      </div>

      <input
        type="range"
        className="og-range og-range-lo"
        min={0}
        max={n - 1}
        step={1}
        value={lo}
        onChange={(e) => setMin(Number(e.target.value))}
        aria-label="Range start year"
      />
      <input
        type="range"
        className="og-range og-range-hi"
        min={0}
        max={n - 1}
        step={1}
        value={hi}
        onChange={(e) => setMax(Number(e.target.value))}
        aria-label="Range end year"
      />

      <div className="og-bubbles">
        {yearData.map((d, i) => {
          const inRange = i >= lo && i <= hi;
          const r = 3 + 9 * Math.sqrt(d.t / maxTotal);
          return (
            <button
              key={d.y}
              className={`og-bubble ${inRange ? "og-bubble-on" : ""}`}
              style={{
                left: `${(i / (n - 1)) * 100}%`,
                width: r * 2,
                height: r * 2,
                marginLeft: -r,
              }}
              title={`${d.y} · ${d.city} · ${fmt(d.t)} medals`}
              onClick={() => setRange([i, i])}
            >
              <span className="og-bubble-dot" />
            </button>
          );
        })}
      </div>

      <div className="og-ticks">
        {years.map((y, i) => {
          const show = i === 0 || i === n - 1 || i % 4 === 0;
          if (!show) return null;
          return (
            <span
              key={y}
              className="og-tick"
              style={{ left: `${(i / (n - 1)) * 100}%` }}
            >
              {y}
            </span>
          );
        })}
      </div>
    </div>
  );
}

function TrendChart({ trend, lo, hi, metric }) {
  const W = 720,
    H = 220,
    PAD = 28;
  const n = trend.length;
  const maxVal =
    Math.max(1, ...trend.map((d) => Math.max(d.t, d.g, d.s, d.b))) * 1.15;

  const xAt = (i) => PAD + (i / (n - 1)) * (W - PAD * 2);
  const yAt = (v) => H - PAD - (v / maxVal) * (H - PAD * 1.6);

  const line = (key) =>
    trend.map((d, i) => `${i === 0 ? "M" : "L"} ${xAt(i)} ${yAt(d[key])}`).join(" ");

  const area =
    `M ${xAt(0)} ${H - PAD} ` +
    trend.map((d, i) => `L ${xAt(i)} ${yAt(d.t)}`).join(" ") +
    ` L ${xAt(n - 1)} ${H - PAD} Z`;

  const bandX1 = xAt(lo);
  const bandX2 = xAt(hi);

  return (
    <svg viewBox={`0 0 ${W} ${H}`} className="og-trend-svg" role="img">
      <rect
        x={bandX1}
        y={4}
        width={Math.max(2, bandX2 - bandX1)}
        height={H - 8}
        fill="rgba(212,175,55,0.10)"
        stroke="rgba(212,175,55,0.35)"
        strokeDasharray="3 3"
      />
      <line x1={PAD} y1={H - PAD} x2={W - PAD} y2={H - PAD} stroke="rgba(241,238,228,0.18)" />
      <path d={area} fill="rgba(241,238,228,0.08)" />
      <path d={line("t")} fill="none" stroke="#EDE9DD" strokeWidth="2" opacity="0.55" />
      <path d={line("g")} fill="none" stroke={MEDAL_COLOR.g} strokeWidth="2.5" />
      <path d={line("s")} fill="none" stroke={MEDAL_COLOR.s} strokeWidth="1.5" opacity="0.85" />
      <path d={line("b")} fill="none" stroke={MEDAL_COLOR.b} strokeWidth="1.5" opacity="0.85" />
      {trend.map((d, i) =>
        d.t > 0 ? (
          <circle key={d.y} cx={xAt(i)} cy={yAt(metric === "gold" ? d.g : d.t)} r="2.6" fill={metric === "gold" ? MEDAL_COLOR.g : "#EDE9DD"}>
            <title>{`${d.y}: ${d.g}G ${d.s}S ${d.b}B`}</title>
          </circle>
        ) : null
      )}
    </svg>
  );
}

function SportBars({ rows }) {
  const max = Math.max(1, ...rows.map((r) => r.t));
  return (
    <div className="og-sportbars">
      {rows.map((r) => (
        <div className="og-sportbar-row" key={r.sp}>
          <span className="og-sportbar-label">{r.sp}</span>
          <div className="og-sportbar-track">
            <div
              className="og-sportbar-fill"
              style={{ width: `${(r.t / max) * 100}%` }}
            />
          </div>
          <span className="og-sportbar-count">{r.t}</span>
        </div>
      ))}
      {rows.length === 0 && (
        <p className="og-empty">No medals recorded for this sport view.</p>
      )}
    </div>
  );
}

